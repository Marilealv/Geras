{
  "name": "geras-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
